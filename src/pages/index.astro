---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getPosts } from '../utils/posts';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from '../consts';

const posts = await getPosts();
const recentPosts = posts.slice(0, 6);

const keywords = ['React', 'TypeScript', 'Astro', '마이그레이션', '아키텍처', '회고'];

// 최근 3편 (hero 영역용)
const latestPosts = posts.slice(0, 3);

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_TITLE,
  url: SITE_URL,
  description: SITE_DESCRIPTION,
  inLanguage: 'ko-KR',
};
---

<BaseLayout description={SITE_DESCRIPTION}>
  <script slot="jsonld" type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
  <div class="container home-container">
    <section class="home-hero" aria-label="소개">
      <p class="home-eyebrow">프론트엔드 개발자</p>
      <h1 class="home-title">코드와 글을<br />함께 설계합니다.</h1>
      <ul class="home-keywords" aria-label="주요 관심 기술">
        {keywords.map((kw) => (
          <li class="home-keyword">{kw}</li>
        ))}
      </ul>
      <div class="home-latest" aria-label="최근 작성 글">
        <span class="home-latest-label">최근 작성</span>
        <ul class="home-latest-list" role="list">
          {latestPosts.map((post) => {
            const daysAgo = Math.floor(
              (Date.now() - post.data.pubDate.getTime()) / (1000 * 60 * 60 * 24)
            );
            const ago = daysAgo === 0 ? '오늘' : `${daysAgo}일 전`;
            return (
              <li class="home-latest-item">
                <span class="home-latest-ago">{ago}</span>
                <a href={`/blog/${post.data.slug}`} class="home-latest-link">
                  {post.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </section>

    <section aria-labelledby="recent-posts-heading">
      <h2 id="recent-posts-heading" class="section-heading">최근 글</h2>
      <div class="post-grid">
        {recentPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
      {posts.length > 6 && (
        <div class="home-more">
          <a href="/blog" class="btn-more">모든 글 보기</a>
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .home-container {
    padding-block: 4rem;
  }

  /* Hero */
  .home-hero {
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  .home-eyebrow {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .home-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.15;
    color: var(--fg);
    margin-bottom: 1.5rem;
  }

  /* 키워드 */
  .home-keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
  }

  .home-keyword {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--fg-muted);
    background-color: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    padding: 0.25rem 0.75rem;
  }

  /* 최근 작성 */
  .home-latest {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .home-latest-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .home-latest-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .home-latest-item {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
  }

  .home-latest-ago {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    min-width: 3.5rem;
  }

  .home-latest-link {
    font-size: 0.9rem;
    color: var(--fg-muted);
    text-decoration: none;
    word-break: keep-all;
    transition: color var(--transition-fast);
  }

  .home-latest-link:hover {
    color: var(--accent);
  }

  .home-latest-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .section-heading {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 1.5rem;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .home-more {
    margin-top: 2rem;
    text-align: center;
  }

  .btn-more {
    display: inline-block;
    padding: 0.625rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .btn-more:hover {
    background-color: var(--bg-hover);
    border-color: var(--border-strong);
  }

  .btn-more:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  @media (max-width: 640px) {
    .home-container {
      padding-block: 2.5rem;
    }
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
