---
import { SITE_TITLE, AUTHOR } from '../consts';

const buildYear = new Date().getFullYear();
const buildDate = new Date().toISOString().slice(0, 16).replace('T', ' ') + ' UTC';
---

<footer class="site-footer" role="contentinfo" data-pagefind-ignore>
  <div class="container footer-inner">
    <p class="footer-copy">
      &copy; {buildYear} <span class="footer-author">{AUTHOR}</span>. All rights reserved.
    </p>

    <nav class="footer-nav" aria-label="푸터 메뉴">
      <a
        href="/rss.xml"
        class="footer-link"
        aria-label="RSS 피드 구독"
        rel="noopener"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        RSS
      </a>
    </nav>

    <p class="footer-build">
      Built <time datetime={new Date().toISOString()}>{buildDate}</time>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    padding-block: 2rem;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--fg-muted);
    margin: 0;
  }

  .footer-author {
    font-weight: 600;
    color: var(--fg);
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8125rem;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer-link:hover {
    color: var(--accent);
  }
  .footer-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  .footer-build {
    margin-left: auto;
    font-size: 0.75rem;
    color: var(--fg-subtle);
    font-variant-numeric: tabular-nums;
    margin-bottom: 0;
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .footer-build {
      margin-left: 0;
    }
  }
</style>
