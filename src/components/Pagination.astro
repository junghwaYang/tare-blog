---
interface Props {
  currentPage: number;
  lastPage: number;
  urlPrev: string | undefined;
  urlNext: string | undefined;
  basePath?: string;
}

const { currentPage, lastPage, urlPrev, urlNext, basePath = '/blog' } = Astro.props;

// 현재 페이지 중심 ±2 윈도우 + 첫/마지막 페이지 항상 표시
const WINDOW = 2;
const pages: number[] = [];
for (let i = 1; i <= lastPage; i++) {
  if (
    i === 1 ||
    i === lastPage ||
    (i >= currentPage - WINDOW && i <= currentPage + WINDOW)
  ) {
    pages.push(i);
  }
}

// 생략 부호 삽입을 위한 렌더 배열
type PageItem = { type: 'page'; num: number } | { type: 'ellipsis'; key: string };
const renderItems: PageItem[] = [];
for (let idx = 0; idx < pages.length; idx++) {
  if (idx > 0 && pages[idx] - pages[idx - 1] > 1) {
    renderItems.push({ type: 'ellipsis', key: `ellipsis-${idx}` });
  }
  renderItems.push({ type: 'page', num: pages[idx] });
}

function pageHref(num: number): string {
  return num === 1 ? basePath.replace(/\/page$/, '') + '/' : `${basePath}/${num}`;
}
---

{lastPage > 1 && (
  <nav class="pagination" aria-label="페이지 네비게이션">
    {urlPrev ? (
      <a href={urlPrev} class="pagination-btn" aria-label="이전 페이지" rel="prev">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </a>
    ) : (
      <span class="pagination-btn pagination-btn--disabled" aria-disabled="true" aria-label="이전 페이지 없음">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </span>
    )}

    <ol class="pagination-pages" role="list">
      {renderItems.map((item) =>
        item.type === 'ellipsis' ? (
          <li>
            <span class="pagination-ellipsis" aria-hidden="true">&hellip;</span>
          </li>
        ) : (
          <li>
            {item.num === currentPage ? (
              <span
                class="pagination-page pagination-page--active"
                aria-current="page"
                aria-label={`현재 페이지, ${item.num} 페이지`}
              >
                {item.num}
              </span>
            ) : (
              <a
                href={pageHref(item.num)}
                class="pagination-page"
                aria-label={`${item.num} 페이지로 이동`}
              >
                {item.num}
              </a>
            )}
          </li>
        )
      )}
    </ol>

    {urlNext ? (
      <a href={urlNext} class="pagination-btn" aria-label="다음 페이지" rel="next">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </a>
    ) : (
      <span class="pagination-btn pagination-btn--disabled" aria-disabled="true" aria-label="다음 페이지 없음">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </span>
    )}
  </nav>
)}

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    margin-top: 3rem;
  }

  .pagination-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--fg-muted);
    text-decoration: none;
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast),
      border-color var(--transition-fast);
  }

  a.pagination-btn:hover {
    color: var(--fg);
    background-color: var(--bg-hover);
    border-color: var(--border-strong);
  }

  a.pagination-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .pagination-btn--disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pagination-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding-inline: 0.5rem;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg-muted);
    text-decoration: none;
    font-variant-numeric: tabular-nums;
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast),
      border-color var(--transition-fast);
  }

  a.pagination-page:hover {
    color: var(--fg);
    background-color: var(--bg-hover);
    border-color: var(--border);
  }

  a.pagination-page:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .pagination-page--active {
    color: var(--accent);
    background-color: var(--accent-subtle);
    border-color: var(--accent);
    font-weight: 700;
    cursor: default;
  }

  .pagination-ellipsis {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font-size: 0.875rem;
    color: var(--fg-subtle);
    user-select: none;
  }
</style>
