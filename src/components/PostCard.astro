---
import type { CollectionEntry } from 'astro:content';
import TagList from './TagList.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, category, slug } = post.data;

const formattedDate = pubDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const pubDateISO = pubDate.toISOString();
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="post-card-link">
    <div class="post-card-inner">
      <div class="post-card-meta-top">
        <span class="post-card-category">{category}</span>
        <time datetime={pubDateISO} class="post-card-date">{formattedDate}</time>
      </div>

      <h2 class="post-card-title">{title}</h2>

      {description && (
        <p class="post-card-description">{description}</p>
      )}
    </div>
  </a>

  {tags.length > 0 && (
    <div class="post-card-tags">
      <TagList items={tags} />
    </div>
  )}
</article>

<style>
  .post-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background-color: var(--bg);
    overflow: hidden;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .post-card:hover {
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .post-card-link {
    display: block;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .post-card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
    border-radius: calc(var(--radius-lg) - 1px);
  }

  .post-card-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-card-meta-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-card-category {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-card-date {
    font-size: 0.8125rem;
    color: var(--fg-subtle);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .post-card-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: var(--fg);
    word-break: keep-all;
    margin: 0;
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-card-title {
    color: var(--accent);
  }

  .post-card-description {
    font-size: 0.9375rem;
    color: var(--fg-muted);
    line-height: 1.6;
    word-break: keep-all;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .post-card-tags {
    padding: 0 1.5rem 1.25rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card:hover {
      transform: none;
    }
  }
</style>
