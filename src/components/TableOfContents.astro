---
/**
 * TableOfContents.astro
 *
 * 사용처:
 * - BlogPost.astro의 .toc-mobile-wrapper (모바일: details/summary)
 * - BlogPost.astro의 .post-toc-aside (데스크톱: sticky 사이드바)
 *
 * 표시/숨김은 부모 래퍼의 CSS로 제어.
 * 이 컴포넌트는 항상 두 가지 형태(사이드바 + 모바일)를 모두 렌더링하지 않음.
 * 부모가 각각 적절한 래퍼로 감싸서 표시를 제어함.
 */
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  /** 'sidebar' = 데스크톱 sticky nav, 'mobile' = details/summary (기본값) */
  variant?: 'sidebar' | 'mobile';
}

const { headings, variant = 'mobile' } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 1 && (
  variant === 'sidebar' ? (
    <nav class="toc-sidebar" aria-label="목차">
      <p class="toc-title">목차</p>
      <ol class="toc-list" role="list">
        {filtered.map((h) => (
          <li class:list={['toc-item', { 'toc-item--h3': h.depth === 3 }]}>
            <a href={`#${h.slug}`} class="toc-link" data-toc-slug={h.slug}>
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  ) : (
    <details class="toc-mobile" id="toc-mobile">
      <summary class="toc-mobile-summary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/>
        </svg>
        목차
      </summary>
      <ol class="toc-mobile-list" role="list">
        {filtered.map((h) => (
          <li class:list={['toc-mobile-item', { 'toc-mobile-item--h3': h.depth === 3 }]}>
            <a href={`#${h.slug}`} class="toc-mobile-link" data-toc-slug={h.slug}>
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </details>
  )
)}

<script is:inline>
  (function () {
    function initTOC() {
      const allLinks = document.querySelectorAll('[data-toc-slug]');
      if (allLinks.length === 0) return;

      const slugs = Array.from(new Set(Array.from(allLinks).map((el) => el.dataset.tocSlug)));
      const headingEls = slugs
        .map((slug) => document.getElementById(slug))
        .filter(Boolean);

      if (headingEls.length === 0) return;

      let activeSlug = null;

      function setActive(slug) {
        if (activeSlug === slug) return;
        activeSlug = slug;
        allLinks.forEach((el) => {
          const isActive = el.dataset.tocSlug === slug;
          el.setAttribute('aria-current', isActive ? 'location' : 'false');
          el.classList.toggle('toc-link--active', isActive);
          el.classList.toggle('toc-mobile-link--active', isActive);
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible.length > 0) setActive(visible[0].target.id);
        },
        { rootMargin: '-64px 0px -60% 0px', threshold: 0 }
      );

      headingEls.forEach((el) => observer.observe(el));

      // 모바일 TOC 링크 클릭 시 자동 닫기
      document.querySelectorAll('.toc-mobile [data-toc-slug]').forEach((link) => {
        link.addEventListener('click', () => {
          const details = link.closest('details');
          if (details) details.removeAttribute('open');
        });
      });
    }

    document.addEventListener('astro:page-load', initTOC);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTOC);
    } else {
      initTOC();
    }
  })();
</script>

<style>
  /* ── 데스크톱 사이드바 nav ─────────────────────────────────── */
  .toc-sidebar {
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border-strong) transparent;
  }
  .toc-sidebar::-webkit-scrollbar { width: 3px; }
  .toc-sidebar::-webkit-scrollbar-thumb {
    background: var(--border-strong);
    border-radius: 9999px;
  }

  .toc-title {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin-bottom: 0.75rem;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .toc-item { line-height: 1.4; }
  .toc-item--h3 { padding-left: 0.875rem; }

  .toc-link {
    display: block;
    padding: 0.25rem 0.5rem;
    font-size: 0.8125rem;
    color: var(--fg-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    border-left: 2px solid transparent;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
    word-break: keep-all;
    line-height: 1.5;
  }
  .toc-link:hover {
    color: var(--fg);
    background-color: var(--bg-subtle);
  }
  .toc-link--active,
  .toc-link[aria-current='location'] {
    color: var(--accent);
    border-left-color: var(--accent);
    background-color: var(--accent-subtle);
    font-weight: 500;
  }

  /* ── 모바일 details/summary ────────────────────────────────── */
  .toc-mobile {
    margin-bottom: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .toc-mobile-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--fg-muted);
    cursor: pointer;
    user-select: none;
    list-style: none;
    background-color: var(--bg-subtle);
    transition: background-color var(--transition-fast);
  }
  .toc-mobile-summary::-webkit-details-marker { display: none; }
  .toc-mobile-summary:hover {
    background-color: var(--bg-hover);
    color: var(--fg);
  }

  .toc-mobile-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .toc-mobile-item { padding-inline: 0.5rem; }
  .toc-mobile-item--h3 { padding-left: 1.5rem; }

  .toc-mobile-link {
    display: block;
    padding: 0.375rem 0.5rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
    word-break: keep-all;
  }
  .toc-mobile-link:hover {
    color: var(--fg);
    background-color: var(--bg-subtle);
  }
  .toc-mobile-link--active,
  .toc-mobile-link[aria-current='location'] {
    color: var(--accent);
    font-weight: 500;
  }
</style>
