---
import type { CollectionEntry } from 'astro:content';

interface Props {
  currentSlug: string;
  seriesName: string;
  seriesPosts: CollectionEntry<'blog'>[];
}

const { currentSlug, seriesName, seriesPosts } = Astro.props;

const sorted = seriesPosts.sort(
  (a, b) => a.data.pubDate.getTime() - b.data.pubDate.getTime()
);
---

<nav class="series-nav" aria-label={`시리즈: ${seriesName}`}>
  <div class="series-header">
    <span class="series-label">시리즈</span>
    <span class="series-name">{seriesName}</span>
    <span class="series-count">{seriesPosts.length}편</span>
  </div>
  <ol class="series-list" role="list">
    {sorted.map((post, index) => {
      const isCurrent = post.data.slug === currentSlug;
      return (
        <li class:list={['series-item', { 'series-item--current': isCurrent }]}>
          {isCurrent ? (
            <span class="series-link series-link--current" aria-current="page">
              <span class="series-index">{index + 1}</span>
              <span class="series-title">{post.data.title}</span>
            </span>
          ) : (
            <a
              href={`/blog/${post.data.slug}`}
              class="series-link"
            >
              <span class="series-index">{index + 1}</span>
              <span class="series-title">{post.data.title}</span>
            </a>
          )}
        </li>
      );
    })}
  </ol>
</nav>

<style>
  .series-nav {
    margin-block: 2rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-md);
    background-color: var(--bg-subtle);
  }

  .series-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
  }

  .series-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .series-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--fg);
  }

  .series-count {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    margin-left: auto;
    font-variant-numeric: tabular-nums;
  }

  .series-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .series-link {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    padding: 0.3rem 0;
    text-decoration: none;
    color: var(--fg-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    transition: color var(--transition-fast);
    border-radius: var(--radius-sm);
  }

  .series-link:hover {
    color: var(--accent);
  }

  .series-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .series-link--current {
    color: var(--fg);
    font-weight: 600;
    cursor: default;
  }

  .series-index {
    flex-shrink: 0;
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    color: var(--fg-subtle);
    min-width: 1.25rem;
    text-align: right;
  }

  .series-item--current .series-index {
    color: var(--accent);
  }

  .series-title {
    word-break: keep-all;
  }
</style>
