---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { SITE_TITLE, SITE_URL, AUTHOR } from '../consts';
import { calcReadingTime } from '../utils/readingTime';
import '../styles/prose.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<'blog'>;
  prevPost?: CollectionEntry<'blog'> | null;
  nextPost?: CollectionEntry<'blog'> | null;
  headings?: Heading[];
}

const { post, prevPost, nextPost, headings = [] } = Astro.props;
const readingTime = calcReadingTime(post.body ?? '');
const { title, description, pubDate, updatedDate, tags, category, ogImage } = post.data;

const formattedPubDate = pubDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const pubDateISO = pubDate.toISOString();
const updatedDateISO = updatedDate?.toISOString();

const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageURL = ogImage ? new URL(ogImage, SITE_URL).href : new URL('/og-default.png', SITE_URL).href;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: ogImageURL,
  datePublished: pubDateISO,
  dateModified: updatedDateISO ?? pubDateISO,
  author: { '@type': 'Person', name: AUTHOR },
  publisher: { '@type': 'Organization', name: SITE_TITLE },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL },
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  category={category}
  tags={tags}
>
  <script slot="jsonld" type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <div class="container post-container">
    <div class="post-layout">
      <article data-pagefind-body class="post-article">
        <!-- Pagefind 카테고리 메타 -->
        <meta data-pagefind-meta="category" content={category} />

        <!-- 포스트 헤더 -->
        <header class="post-header">
          <div class="post-meta-top">
            <a
              href={`/categories/${category}`}
              class="post-category"
              aria-label={`카테고리: ${category}`}
            >
              {category}
            </a>
          </div>

          <h1 class="post-title">{title}</h1>

          {description && (
            <p class="post-description">{description}</p>
          )}

          <div class="post-meta">
            <time datetime={pubDateISO} class="post-date">
              {formattedPubDate}
            </time>
            <span class="post-reading-time" aria-label={`읽기 시간 약 ${readingTime}분`}>
              · 약 {readingTime}분
            </span>
            {updatedDate && (
              <span class="post-updated">
                (수정: <time datetime={updatedDateISO}>{formattedUpdatedDate}</time>)
              </span>
            )}
          </div>

          {tags.length > 0 && (
            <div class="post-tags">
              <TagList items={tags} />
            </div>
          )}
        </header>

        <hr class="post-divider" />

        <!-- 모바일 전용 TOC (1200px 미만에서만 표시) -->
        <div class="toc-mobile-wrapper">
          <TableOfContents headings={headings} variant="mobile" />
        </div>

        <!-- 본문 -->
        <div class="prose">
          <slot />
        </div>
      </article>

      <!-- 데스크톱 전용 TOC 사이드바 (1200px 이상에서만 표시) -->
      <aside class="post-toc-aside" aria-label="목차">
        <TableOfContents headings={headings} variant="sidebar" />
      </aside>
    </div>

    <!-- 이전/다음 글 네비 -->
    {(prevPost || nextPost) && (
      <nav class="post-nav" aria-label="이전/다음 글">
        <div class="post-nav-inner">
          {prevPost ? (
            <a
              href={`/blog/${prevPost.data.slug}`}
              class="post-nav-link post-nav-link--prev"
              rel="prev"
            >
              <span class="post-nav-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                이전 글
              </span>
              <span class="post-nav-title">{prevPost.data.title}</span>
            </a>
          ) : (
            <div></div>
          )}

          {nextPost ? (
            <a
              href={`/blog/${nextPost.data.slug}`}
              class="post-nav-link post-nav-link--next"
              rel="next"
            >
              <span class="post-nav-label">
                다음 글
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
              <span class="post-nav-title">{nextPost.data.title}</span>
            </a>
          ) : (
            <div></div>
          )}
        </div>
      </nav>
    )}
  </div>
</BaseLayout>

<style>
  .post-container {
    padding-block: 3rem;
  }

  /* 2컬럼 레이아웃: 본문 + TOC 사이드바 */
  .post-layout {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .post-article {
    flex: 1;
    min-width: 0;
    max-width: var(--prose-width, 68ch);
    margin-inline: auto;
  }

  /* 모바일 TOC 래퍼: 1200px 미만에서만 표시 */
  .toc-mobile-wrapper {
    display: block;
  }
  @media (min-width: 1200px) {
    .toc-mobile-wrapper {
      display: none;
    }
  }

  /* 데스크톱 TOC 사이드바: 1200px 이상에서만 표시 */
  .post-toc-aside {
    display: none;
  }

  @media (min-width: 1200px) {
    .post-layout {
      max-width: calc(var(--prose-width, 68ch) + 220px + 3rem);
      margin-inline: auto;
    }
    .post-article {
      margin-inline: 0;
    }
    .post-toc-aside {
      display: block;
      width: 220px;
      flex-shrink: 0;
    }
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-meta-top {
    margin-bottom: 0.75rem;
  }

  .post-category {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .post-category:hover {
    color: var(--accent-hover);
  }
  .post-category:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: var(--fg);
    margin-bottom: 0.75rem;
    word-break: keep-all;
  }

  .post-description {
    font-size: 1.0625rem;
    color: var(--fg-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
    word-break: keep-all;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
    flex-wrap: wrap;
  }

  .post-date {
    font-variant-numeric: tabular-nums;
  }

  .post-reading-time {
    font-size: 0.875rem;
    color: var(--fg-muted);
    font-variant-numeric: tabular-nums;
  }

  .post-updated {
    font-size: 0.8125rem;
    color: var(--fg-subtle);
  }

  .post-tags {
    margin-top: 0.875rem;
  }

  .post-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin-block: 2rem;
  }

  /* 이전/다음 네비 */
  .post-nav {
    max-width: var(--prose-width, 68ch);
    margin-inline: auto;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  @media (min-width: 1200px) {
    .post-nav {
      max-width: calc(var(--prose-width, 68ch) + 220px + 3rem);
    }
  }

  .post-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--fg);
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }
  .post-nav-link:hover {
    border-color: var(--border-strong);
    background-color: var(--bg-subtle);
  }
  .post-nav-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .post-nav-link--next {
    text-align: right;
  }

  .post-nav-label {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .post-nav-link--next .post-nav-label {
    justify-content: flex-end;
  }

  .post-nav-title {
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.4;
    word-break: keep-all;
  }

  @media (max-width: 640px) {
    .post-container {
      padding-block: 2rem;
    }
    .post-nav-inner {
      grid-template-columns: 1fr;
    }
    .post-nav-link--next {
      text-align: left;
    }
    .post-nav-link--next .post-nav-label {
      justify-content: flex-start;
    }
  }
</style>
